# Edit this config, then run:
#   bash scripts/run_full_pipeline.sh configs/full_pipeline.env

# Required paths.
SOURCE_PATH="audios"
WORKSPACE="pipeline_runs/default"

# Runtime.
PYTHON_BIN="python"
DEVICE="cuda:0"
OVERWRITE=true
RECURSIVE=true

# Stage switches.
DO_CONVERT=true
DO_MUSIC=false
DO_DENOISE=true
DO_PRESPLIT=false
DO_SLICE=true
DO_SPEAKER_FILTER=false
DO_VOLUME_NORMALIZE=false

# 01 conversion.
SAMPLE_RATE=16000
START_INDEX=1
DIGITS=3

# 02 music removal.
DEMUCS_MODEL="htdemucs"
DEMUCS_SHIFTS=1
DEMUCS_JOBS=0
# Set to an empty string to omit --segment.
DEMUCS_SEGMENT=""

# 03 denoising. Options: MossFormer2, ZipEnhancer.
DENOISE_METHOD="MossFormer2"
MOSSFORMER_MODEL_PATH="checkpoints/MossFormer2_SE_48K"
MOSSFORMER_CPU=false
PREPROCESS_WORKERS=4
INFERENCE_BATCH_SIZE=4
ZIP_MODEL="checkpoints/ZipEnhancer"
ZIP_NORMALIZE="match_original"
ZIP_ALIGNMENT_METRIC="rms"

# 03b optional long-audio pre-split.
PRESPLIT_TARGET_PIECE_SECONDS=300
PRESPLIT_SEARCH_WINDOW_SECONDS=60
PRESPLIT_FRAME_MS=30
PRESPLIT_HOP_MS=10
PRESPLIT_MIN_SILENCE_MS=500

# 04 slicing. Options: rule, llm.
SLICE_MODE="rule"
ASR_MODEL_PATH="checkpoints/Qwen3-ASR-1.7B"
ALIGNER_PATH="checkpoints/Qwen3-ForcedAligner-0.6B"
ASR_BACKEND="transformers"
# JSON passed to --asr-backend-kwargs. Useful for vLLM tuning, for example:
# ASR_BACKEND_KWARGS='{"gpu_memory_utilization":0.95,"max_model_len":8192,"max_num_batched_tokens":32768,"max_num_seqs":64}'
ASR_BACKEND_KWARGS="{}"
DTYPE="bfloat16"
ASR_MAX_BATCH_SIZE=8
ALIGNER_MAX_BATCH_SIZE=1
# Pre-pass chunking. rms_silence cuts the source into small windows first,
# then ASR and forced-aligns each same-window transcript/audio pair.
PREPROCESS_CHUNK_MODE="rms_silence"
PREPROCESS_CHUNK_SEC=30
PREPROCESS_MIN_CHUNK_SEC=5
PREPROCESS_MAX_CHUNK_SEC=15
RMS_SILENCE_FRAME_MS=25
RMS_SILENCE_HOP_MS=5
RMS_SILENCE_PERCENTILE=25
RMS_SILENCE_THRESHOLD_MULTIPLIER=1.8
RMS_MIN_SILENCE_MS=80
MIN_SEG_SEC=3
MAX_SEG_SEC=10
LANGUAGE=""
VAD_BACKEND="auto"
ROUGH_CUT_STRATEGY="priority_silence_v2" # rule: legacy_dp, priority_silence_v1, priority_silence_v2, dp_strategy_2; llm: llm_pause_priority_silence_v2, llm_tool, or rule strategies
ENABLE_PUNCTUATION_CORRECTION=false
DRY_RUN=false

# LLM slicing settings, used only when SLICE_MODE=llm.
LLM_MODEL=""
PUNCT_LLM_MODEL=""
ROUGH_LLM_MODEL=""
LLM_PROVIDER=""
ENV_PATH=".env"
LLM_CONCURRENCY=8
LLM_MAX_ROUNDS=5

# 04b optional speaker outlier filtering.
SPEAKER_DEVICE="cuda:0"
SPEAKER_MODEL_SOURCE="checkpoints/spkrec-ecapa-voxceleb"
SPEAKER_MODEL_DIR="checkpoints/spkrec-ecapa-voxceleb"
SPEAKER_MAD_MULTIPLIER=3.0
SPEAKER_MAX_PRUNE_RATIO=0.10
SPEAKER_MIN_ROWS=8

# 05 optional final volume normalization.
VOLUME_TARGET_LUFS=-20
VOLUME_MAX_VOLUME_CHANGE_DB=12
VOLUME_MAX_DYNAMIC_RANGE_DB=24
VOLUME_PEAK_MARGIN_DB=1
VOLUME_MIN_ACTIVE_RATIO=0.03
# 0 keeps source sample rate.
VOLUME_SAMPLE_RATE=0
