# SegmentScribe LLM gateway configuration.
#
# Usage:
# 1. Copy this file to `.env`.
# 2. Fill in only the providers you want to use.
# 3. Keep `.env` private. It is ignored by Git.
#
# Proxy/base URL notes:
# - If you use an official provider endpoint, leave the *_PROXY_URL lines empty
#   or commented out.
# - If you use a proxy, gateway, or OpenAI-compatible relay, uncomment the
#   matching *_PROXY_URL line and set it to that service's `/v1` base URL.
# - Do not put API keys in `.env.example`; put real keys only in `.env`.

# OpenAI-compatible endpoint.
OPENAI_KEY=""
#OPENAI_PROXY_URL=""

# Anthropic-compatible endpoint.
ANTHROPIC_KEY=""
#ANTHROPIC_PROXY_URL=""

# xAI/Grok-compatible endpoint, if supported by your local gateway setup.
GROK_KEY=""
#GROK_PROXY_URL=""

# Gemini-compatible endpoint.
GEMINI_KEY=""
#GEMINI_PROXY_URL=""

# MiniMax-compatible endpoint.
MINIMAX_KEY=""
#MINIMAX_PROXY_URL=""

# DeepSeek official endpoint works without a proxy URL.
DEEPSEEK_API_KEY=""
#DEEPSEEK_PROXY_URL=""

# Optional Langfuse tracing.
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL=""
